# Database Connection
# Neon: go to console.neon.tech → your project → Connection Details
#   Direct URL  (no -pooler in hostname) → use for migrations: dotnet ef database update --connection "..."
#   Pooled URL  (-pooler in hostname)    → use for runtime (production with many users)
# For local development the direct URL works for both.
DB_CONNECTION_STRING=Host=ep-xxx.us-east-2.aws.neon.tech;Database=neondb;Username=user;Password=pass;SSL Mode=Require
DB_MIGRATION_STRING=Host=ep-xxx.us-east-2.aws.neon.tech;Database=neondb;Username=user;Password=pass;SSL Mode=Require
# JWT Settings
JWT_SECRET_KEY=ThisIsASecretKeyForJWTSigningDoNotUseInProduction
JWT_ISSUER=MobileApi
JWT_AUDIENCE=MobileApp
JWT_EXPIRY_MINUTES=60

# Groq LLM (free tier) - for Gravity AI Chat
# Get key at: console.groq.com
GROQ_API_KEY=
